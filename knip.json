{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/{page,layout,route,loading,error,not-found}.{ts,tsx}",
    "src/auth.ts",
    "scripts/**/*.{ts,mjs}",
    "src/components/icons/platform-icons.tsx",
    "src/components/ui/dialog.tsx",
    "src/lib/brief-api.ts",
    "src/lib/campaign-steps.ts",
    "src/lib/omise.ts",
    "src/lib/queue/dead-letter-queue.ts",
    "src/hooks/use-image-upload.ts",
    "src/hooks/use-qr-payment.ts",
    "src/lib/campaign-detail-utils.ts",
    "src/lib/validations/brief.ts",
    "src/lib/validations/campaign-status.ts",
    "src/lib/validations/campaign-update.ts",
    "src/stores/campaign-store.ts",
    "src/types/index.ts"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignoreDependencies": [
    "tw-animate-css",
    "@hookform/resolvers",
    "pg",
    "react-hook-form",
    "shadcn",
    "@bull-board/api",
    "@bull-board/express",
    "@types/pg",
    "@vitejs/plugin-react",
    "tailwindcss",
    "postcss"
  ]
}
