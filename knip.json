{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/app/**/{page,layout,route,loading,error,not-found}.{ts,tsx}",
    "src/proxy.ts",
    "src/auth.ts",
    "src/workers/payment-worker.ts",
    "prisma/seed.ts",
    "scripts/**/*.{ts,mjs}"
  ],
  "project": ["src/**/*.{ts,tsx}"],
  "ignore": [
    "src/generated/**",
    "src/**/__tests__/**",
    "src/**/*.test.{ts,tsx}"
  ],
  "ignoreDependencies": [
    "tw-animate-css",
    "@tailwindcss/postcss"
  ]
}
